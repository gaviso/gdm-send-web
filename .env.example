# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backblaze B2 (S3-compatible)
B2_ENDPOINT=https://s3.us-west-001.backblazeb2.com
B2_REGION=us-west-001
B2_BUCKET_NAME=gdm-send
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-application-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAX_FILE_SIZE=5368709120
NEXT_PUBLIC_MAX_TRANSFER_SIZE=5368709120

# Admin
ADMIN_EMAIL=admin@gaviso.agency
